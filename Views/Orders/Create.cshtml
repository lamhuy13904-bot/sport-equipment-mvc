@model SportEquipment.Mvc.ViewModels.OrderCreateViewModel
@{
    ViewData["Title"] = "Tạo đơn xuất kho";
}

<h2 class="mb-4 text-primary">Tạo Đơn Xuất Kho / Bán Hàng</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3 fs-5"></div>

                <div class="mb-3">
                    <label asp-for="CustomerName" class="form-label fw-bold">Tên người nhận / Khách hàng</label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Nhập tên..." />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EquipmentId" class="form-label fw-bold">Chọn Dụng cụ thể thao</label>
                    <select asp-for="EquipmentId" class="form-select" asp-items="ViewBag.EquipmentList">
                        <option value="">-- Chọn dụng cụ trong kho --</option>
                    </select>
                    <span asp-validation-for="EquipmentId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label fw-bold">Số lượng xuất</label>
                    <input asp-for="Quantity" type="number" class="form-control" placeholder="Nhập số lượng..." min="1" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success w-100">
                    Xác nhận xuất kho
                </button>
            </form>
        </div>
    </div>
</div>