@model SportEquipment.Mvc.ViewModels.EquipmentListItemViewModel
<div class="card shadow-sm h-100">
    <div class="card-body">
        <h5 class="card-title text-primary fw-bold">@Model.Name</h5>
        <h6 class="card-subtitle mb-2 text-muted">Mã: @Model.Code | Hãng: @Model.Brand</h6>
        <p class="card-text text-danger fs-5 fw-bold my-3">@Model.PriceText</p>
        <p class="card-text mb-1">Số lượng: <strong>@Model.Quantity</strong></p>
        
        @if (Model.Status == "Sẵn sàng")
        {
            <span class="badge bg-success mb-3">@Model.Status</span>
        }
        else if (Model.Status == "Sắp hết")
        {
            <span class="badge bg-warning text-dark mb-3">@Model.Status</span>
        }
        else
        {
            <span class="badge bg-danger mb-3">@Model.Status</span>
        }
        
        <div class="mt-auto pt-3 border-top">
            <a class="btn btn-outline-primary w-100" asp-controller="Equipments" asp-action="Detail" asp-route-id="@Model.Id">Xem chi tiết</a>
        </div>
    </div>
</div>