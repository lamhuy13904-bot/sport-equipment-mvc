@model SportEquipment.Mvc.Models.Equipment

@{
    ViewData["Title"] = "Chi tiết thiết bị";
    
    // Tự động tính toán gợi ý dựa vào số lượng và hạn mức tối thiểu
    string suggestion = "Tồn kho an toàn, chưa cần nhập thêm.";
    if (Model.Quantity == 0)
    {
        suggestion = "Hết hàng! Cần liên hệ nhà cung cấp nhập thêm ngay lập tức.";
    }
    else if (Model.Quantity <= Model.MinStock)
    {
        suggestion = "Hàng sắp hết (dưới hạn mức tối thiểu). Hãy lên kế hoạch đặt hàng.";
    }
}

<div class="container mt-4">
    <div class="card p-4 shadow-sm" style="max-width: 500px;">
        <h3 class="text-primary">@Model.Name</h3>
        <p><strong>Mã thiết bị:</strong> @Model.Code</p>
        <p><strong>Thương hiệu:</strong> @Model.Brand</p>
        <p><strong>Giá bán:</strong> <span class="text-danger fw-bold">@Model.Price.ToString("N0") VNĐ</span></p>
        <p><strong>Số lượng hiện tại:</strong> @Model.Quantity sản phẩm</p>
        <p><strong>Hạn mức tối thiểu:</strong> @Model.MinStock sản phẩm</p>
        <p><strong>Danh mục:</strong> @(Model.Category?.Name ?? "Chưa phân loại")</p>
        
        <div class="alert alert-secondary mt-3">
            <strong>Gợi ý:</strong> @suggestion
        </div>
        
        <div class="d-flex gap-2 mt-4">
            @* Nút Sửa *@
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold">
                <i class="bi bi-pencil-square"></i> Chỉnh sửa
            </a>
            
            @* Nút Xóa Mềm *@
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger fw-bold" onclick="return confirm('Bạn có chắc chắn muốn xóa (đưa vào thùng rác) dụng cụ này?');">
                    <i class="bi bi-trash"></i> Xóa
                </button>
            </form>

            @* Nút Quay lại *@
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
            
            @* Nút Kiểm Kho Nhanh *@
            <a asp-action="AdjustStock" asp-route-id="@Model.Id" class="btn btn-info text-white fw-bold">Kiểm Kho</a>
        </div>
    </div>
</div>