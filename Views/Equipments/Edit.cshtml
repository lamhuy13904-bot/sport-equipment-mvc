@model SportEquipment.Mvc.ViewModels.EquipmentEditViewModel

@{
    ViewData["Title"] = "Cập Nhật Dụng Cụ";
}

<h2 class="text-warning mb-4 fw-bold">Chỉnh Sửa Thông Tin</h2>

<div class="card shadow-sm p-4" style="max-width: 600px;">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @* Đổi ModelOnly thành All để phơi bày mọi lỗi ẩn ra màn hình *@
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold="></div>
        @* 2 TRƯỜNG ẨN CỰC KỲ QUAN TRỌNG ĐỂ EF CORE NHẬN DIỆN VÀ CHỐNG GHI ĐÈ *@
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />

        <div class="mb-3">
            <label class="form-label fw-bold">Tên dụng cụ</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Mã thiết bị (Code)</label>
            <input asp-for="Code" class="form-control" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Thương hiệu</label>
            <input asp-for="Brand" class="form-control" />
            <span asp-validation-for="Brand" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                <input asp-for="Price" type="number" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Số lượng</label>
                <input asp-for="Quantity" type="number" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Mức tồn tối thiểu</label>
                <input asp-for="MinStock" type="number" class="form-control" />
                <span asp-validation-for="MinStock" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Mã Danh mục (ID)</label>
            <input asp-for="CategoryId" type="number" class="form-control" />
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-warning fw-bold px-4">Lưu Thay Đổi</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}