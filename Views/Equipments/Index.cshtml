@model List<EquipmentListItemViewModel>
@{
    ViewData["Title"] = "Danh mục thiết bị";
    var totalItems = Model.Count;
}

<div class="page-header">
    <div>
        <h2 class="page-title">Danh Mục Dụng Cụ Thể Thao</h2>
        <p class="page-description">Giao diện danh sách được tổ chức lại bằng Layout và Partial View (Card).</p>
    </div>
    <div>
        <a class="btn btn-secondary" asp-controller="Equipments" asp-action="Search">Tìm kiếm</a>
        <a class="btn" asp-controller="Equipments" asp-action="Create">Thêm mới</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">
        @TempData["SuccessMessage"]
    </div>
}

<p style="margin-bottom: 20px; font-weight: bold; color: #475569;">Tổng số dụng cụ hiện có: @totalItems</p>

@if (Model.Count == 0)
{
    <p>Kho đang trống.</p>
}
else
{
    <div class="product-grid">
        @foreach (var item in Model)
        {
            <partial name="_EquipmentCard" model="item" />
        }
    </div>
}