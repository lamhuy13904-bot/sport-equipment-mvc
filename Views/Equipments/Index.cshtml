@model List<SportEquipment.Mvc.ViewModels.EquipmentListItemViewModel>
@{
    ViewData["Title"] = "Danh mục thiết bị";
    var totalItems = Model.Count;
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="page-title text-primary fw-bold">Danh Mục Dụng Cụ Thể Thao</h2>
        <p class="page-description text-muted">Giao diện danh sách (Chỉ hiển thị các sản phẩm đang hoạt động).</p>
    </div>
    <div>
        <a class="btn btn-secondary fw-bold" asp-controller="Equipments" asp-action="Search">
            <i class="bi bi-search"></i> Tìm kiếm
        </a>
        <a class="btn btn-success fw-bold" asp-controller="Equipments" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Thêm mới
        </a>
    </div>
</div>

@* Khối hiển thị thông báo thành công (Chỉ để 1 lần duy nhất ở đây) *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm fw-bold mt-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p style="margin-bottom: 20px; font-weight: bold; color: #475569;">
    Tổng số dụng cụ hiện có: <span class="text-primary">@totalItems</span>
</p>

@if (Model.Count == 0)
{
    <div class="alert alert-warning text-center fw-bold shadow-sm">
        Kho đang trống hoặc tất cả dụng cụ đã bị đưa vào thùng rác.
    </div>
}
else
{
    <div class="product-grid">
        @foreach (var item in Model)
        {
            <partial name="_EquipmentCard" model="item" />
        }
    </div>
}