@model EquipmentCreateViewModel

@{
    ViewData["Title"] = "Thêm Dụng Cụ Mới";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-lg border-0 rounded-lg">
            
            <div class="card-header bg-primary text-white text-center py-3">
                <h3 class="mb-0 fw-bold">Thêm Dụng Cụ Thể Thao Mới</h3>
            </div>
            
            <div class="card-body p-5 bg-light">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-bold">Tên thiết bị</label>
                            <input asp-for="Name" class="form-control border-secondary bg-white py-2" placeholder="Nhập tên thiết bị..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Brand" class="form-label fw-bold">Hãng sản xuất</label>
                            <input asp-for="Brand" class="form-control border-secondary bg-white py-2" placeholder="Nhập hãng sản xuất..." />
                            <span asp-validation-for="Brand" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ)</label>
                            <input asp-for="Price" type="number" class="form-control border-secondary bg-white py-2" placeholder="0" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Quantity" class="form-label fw-bold">Số lượng nhập</label>
                            <input asp-for="Quantity" type="number" class="form-control border-secondary bg-white py-2" placeholder="0" min="0" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MinStock" class="form-label fw-bold">Mức tối thiểu</label>
                            <input asp-for="MinStock" type="number" class="form-control border-secondary bg-white py-2" placeholder="0" min="0" />
                            <span asp-validation-for="MinStock" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-3 mt-5">
                        <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                            Xác nhận lưu thông tin
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary fw-bold">
                            Hủy bỏ & Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>