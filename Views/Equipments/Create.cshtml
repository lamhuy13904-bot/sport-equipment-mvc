@model EquipmentCreateViewModel
@{
    ViewData["Title"] = "Thêm thiết bị mới";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Thêm Dụng Cụ Mới</h2>
        <p class="page-description">Dùng Tag Helpers asp-for để tự động map dữ liệu.</p>
    </div>
    <a class="btn btn-light" asp-controller="Equipments" asp-action="Index">Về danh sách</a>
</div>

<div class="form-layout">
    <form class="form-box" asp-controller="Equipments" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        <div class="form-group">
            <label asp-for="Name">Tên dụng cụ thể thao</label>
            <input asp-for="Name" class="form-control" placeholder="VD: Balo thể thao chống nước" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="Brand">Thương hiệu / Nhà sản xuất</label>
            <input asp-for="Brand" class="form-control" placeholder="VD: Adidas" />
            <span asp-validation-for="Brand" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price">Giá bán (VND)</label>
            <input asp-for="Price" class="form-control" type="number" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Quantity">Số lượng nhập kho ban đầu</label>
            <input asp-for="Quantity" class="form-control" type="number" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MinStock">Cảnh báo tồn kho khi dưới</label>
            <input asp-for="MinStock" class="form-control" type="number" />
            <span asp-validation-for="MinStock" class="text-danger"></span>
        </div>

        <button class="btn" type="submit">Lưu Sản Phẩm</button>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}